# Frontend-safe variables exposed to the Vite app
VITE_APP_NAME=TeamSupportPro
VITE_GOOGLE_CLIENT_ID=
# Leave blank when the frontend is served by the same Express app.
# Set to your API origin when the frontend is hosted separately.
VITE_API_BASE_URL=

# Backend server variables
NODE_ENV=development
SERVER_PORT=3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
JWT_SECRET=
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
COOKIE_SAME_SITE=lax

# SQL Server variables
DB_SERVER=
DB_PORT=1433
DB_DATABASE=
DB_USER=
DB_PASSWORD=
AUTH_USER_LOOKUP_QUERY=SELECT TOP 1 CAST(u.Id as nvarchar(100)) as userId, COALESCE(u.DisplayName, u.Name, @name) as displayName, u.Email as email, CAST(COALESCE(t.Id, u.TeamId) as nvarchar(100)) as teamId, COALESCE(t.Name, 'IT Support') as teamName, COALESCE(t.Code, 'IT') as teamCode, COALESCE(t.AccentColor, '#0078d4') as teamAccent, COALESCE(u.Role, 'Staff') as role FROM dbo.Users u LEFT JOIN dbo.Teams t ON t.Id = u.TeamId WHERE LOWER(u.Email) = LOWER(@email)